# FantasyFuel Frontend — Environment Variables
# Copy to .env.local and fill in values.

# Chrome path for react-snap pre-rendering (required for `npm run build`)
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux: /usr/bin/google-chrome or /usr/bin/chromium
PUPPETEER_EXECUTABLE_PATH=

# Enable the Sign In / Sign Out tab in the nav header.
# Omit or leave empty to hide auth UI (default for v1).
# REACT_APP_AUTH_ENABLED=true

# Sentry error tracking DSN (optional, omit to disable).
# REACT_APP_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
