# SENTRY-2: stream EB instance logs (incl. the app container stdout where the
# EVAL-4 grading watchdog emits eval_heartbeat_missed / grading_lag) to
# CloudWatch Logs. This is the Sentry-INDEPENDENT signal path: a CloudWatch
# Logs metric filter on this log group feeds an alarm → SNS → phone, so a
# grading freeze reaches us even when the Sentry cron pipeline is dead
# (SENTRY-1: the eval-scheduler cron monitor was auto-disabled all tournament).
#
# On the AL2 Docker platform the default streamed set includes
# /var/log/eb-docker/containers/eb-current-app/*-stdouterr.log → log group
#   /aws/elasticbeanstalk/fantasyfuel-docker3/var/log/eb-docker/containers/eb-current-app/<id>-stdouterr.log
option_settings:
  - namespace: aws:elasticbeanstalk:cloudwatch:logs
    option_name: StreamLogs
    value: "true"
  - namespace: aws:elasticbeanstalk:cloudwatch:logs
    option_name: DeleteOnTerminate
    value: "false"
  - namespace: aws:elasticbeanstalk:cloudwatch:logs
    option_name: RetentionInDays
    value: "7"
